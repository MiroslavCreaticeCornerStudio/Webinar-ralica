---
const items = [
  {
    icon: "learn-icon-1-checks.svg",
    title: "От случайна възможност към повтаряем резултат",
    text: "Ще говорим за разликата между това да чакаш „да ти падне“ добра сделка и това да работиш с ясна система, която ти помага да създаваш повече възможности във времето.",
  },
  {
    icon: "learn-icon-2-handshake.svg",
    title: "Как се правят сделки за милиони?",
    text: "Ще започнем с големия въпрос: какво реално стои зад мащабните сделки в имотите и защо те не са резултат само от късмет, чар или „правилен момент“.",
  },
  {
    icon: "learn-icon-3-chartline.svg",
    title: "Ефектът на сложната лихва",
    text: "Ще видиш как малките действия като контакти, препоръки, доверие, дисциплина и постоянство започват да се натрупват и с времето водят до по-големи клиенти, по-силни сделки и по-стабилен доход.",
  },
  {
    icon: "learn-icon-4-listnumbers.svg",
    title: "Следваща стъпка за повече дълбочина",
    text: "В края на уебинара ще има специален подарък за всеки, който иска повече практически насоки, повече яснота и по-конкретен път към увеличаване и стабилизиране на дохода си.",
  },
  {
    icon: "learn-icon-5-usersfour.svg",
    title: "Силата на средата и екипа",
    text: "Ще разбереш как правилната среда, хората около теб и стандартите, в които работиш, могат да се превърнат в реален инструмент за по-бързо развитие и увеличаване на дохода.",
  },
  {
    icon: "learn-icon-6-chartbar.svg",
    title: "Цифрите зад най-добрите резултати",
    text: "Ще разгледаме как изглеждат резултатите на най-добрите брокери във времето и какво стои зад тях като начин на работа, постоянство, темпо и натрупване.",
  },
];
---

<section class="learn" id="learn">
  <div class="learn__inner container container--padded">
    <div class="learn__header">
      <span class="learn__eyebrow" aria-hidden="true"></span>
      <h2 class="learn__title">Какво ще научиш?</h2>
    </div>

    <div class="learn__grid">
      {
        items.map((item) => (
          <article class="learn__card">
            <div class="learn__head">
              <img class="learn__icon" src={`/assets/images/${item.icon}`} alt="" width="42" height="42" />
              <h3 class="learn__card-title">{item.title}</h3>
              <p class="learn__card-text">{item.text}</p>
            </div>
            <span class="learn__underline" aria-hidden="true"></span>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .learn {
    width: 100%;
    background: var(--color-bg-white);
  }

  .learn__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3.75em; /* 60px */
    padding-top: 5em; /* 80px */
    padding-bottom: 5em;
  }

  .learn__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25em;
  }

  .learn__eyebrow {
    display: block;
    width: 2.5em;
    height: 2px;
    background-color: var(--color-primary);
  }

  .learn__title {
    font-size: 2.625em; /* 42px */
    font-weight: 500;
    line-height: 1.2;
    color: #1c1c1c;
    text-align: center;
  }

  .learn__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    column-gap: 3.5em; /* 56px */
    row-gap: 2.625em; /* 42px */
    width: 100%;
  }

  .learn__card {
    display: flex;
    flex-direction: column;
  }

  .learn__head {
    display: flex;
    flex-direction: column;
    gap: 1em; /* 16px */
    padding-bottom: 2em; /* min 32px gap before the underline */
  }

  .learn__icon {
    width: 2.625em; /* 42px */
    height: 2.625em;
  }

  .learn__card-title {
    font-size: 1.5em; /* 24px */
    font-weight: 500;
    line-height: 1.4;
    color: var(--color-primary);
  }

  .learn__card-text {
    font-size: 1em; /* 16px */
    font-weight: 400;
    line-height: 1.6875; /* 27px / 16px */
    color: var(--color-text-secondary);
  }

  .learn__underline {
    display: block;
    margin-top: auto; /* aligns underlines across each row */
    height: 1px;
    background-color: var(--color-border);
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 991px) {
    .learn__grid {
      grid-template-columns: repeat(2, 1fr);
      column-gap: 2.5em;
    }

    .learn__title {
      font-size: 2.1em;
    }
  }

  @media (max-width: 767px) {
    .learn__inner {
      gap: 2.5em;
      padding-top: 3em;
      padding-bottom: 3em;
    }

    .learn__grid {
      grid-template-columns: 1fr;
      row-gap: 2em;
    }
  }
</style>
