---
import { webinar } from "../data/webinar";

const quickLinks = [
  { label: "За кого е подходящо", href: "/#who" },
  { label: "Какво ще научиш", href: "/#learn" },
  { label: "За лектора", href: "/#speaker" },
];
---

<footer class="footer">
  <div class="footer__main container container--padded">
    <div class="footer__brand">
      <a class="footer__logo" href="/deals-worth-millions" aria-label={`${webinar.brand} начало`}>
        <img src="/assets/images/logo-home2u-icon.svg" alt="" width="31" height="31" />
        <img src="/assets/images/logo-home2u-text.svg" alt={webinar.brand} width="129" height="31" />
      </a>
      <p class="footer__about">
        Home2U - One of the World’s leading hybrid real estate companies is now in Dubai!
      </p>
    </div>

    <nav class="footer__nav" aria-label="Долна навигация">
      <div class="footer__col">
        <p class="footer__col-title">Уебинар</p>
        <ul class="footer__links">
          {quickLinks.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
        </ul>
      </div>

      <div class="footer__col footer__col--contacts">
        <p class="footer__col-title">Контакти</p>
        <ul class="footer__contacts">
          <li>
            <img src="/assets/images/footer-icon-phone.svg" alt="" width="14" height="14" />
            <a href="tel:+35988788333222">+359 887 88333222</a>
          </li>
          <li>
            <img src="/assets/images/footer-icon-email.svg" alt="" width="16" height="14" />
            <a href="mailto:info@home2u.com">info@home2u.com</a>
          </li>
        </ul>
      </div>
    </nav>
  </div>

  <div class="footer__bar">
    <div class="footer__bar-inner container container--padded">
      <div class="footer__legal">
        <a href="/privacy">Защита на личните данни</a>
        <span aria-hidden="true">|</span>
        <a href="/zzlpspoin">Информация по ЗЗЛПСПООИН</a>
      </div>
      <p class="footer__copy">“Home2U Недвижими Имоти” 2026 година</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    width: 100%;
    background: var(--color-bg-white);
  }

  .footer__main {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 3em;
    padding-top: 4em; /* 64px */
    padding-bottom: 3em;
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: 1.5em; /* 24px */
    width: 20.25em; /* 324px */
  }

  .footer__logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
  }

  .footer__logo img {
    height: 1.95em;
    width: auto;
  }

  .footer__about {
    font-size: 0.875em; /* 14px */
    line-height: 1.5;
    color: var(--color-text-secondary);
  }

  .footer__nav {
    display: flex;
    gap: 4.75em;
  }

  .footer__col {
    display: flex;
    flex-direction: column;
    gap: 1.6875em; /* ~27px */
  }

  .footer__col--contacts {
    width: 15.8em; /* 253px */
  }

  .footer__col-title {
    padding-bottom: 0.5625em; /* ~9px */
    font-size: 1.125em; /* 18px */
    line-height: 1.3;
    color: #1c1c1c;
    border-bottom: 1px solid #c6c6c6;
  }

  .footer__links {
    display: flex;
    gap: 2.5em; /* 40px */
    flex-wrap: wrap;
  }

  .footer__links a,
  .footer__contacts a {
    font-size: 0.875em; /* 14px */
    line-height: 1.3;
    color: #1c1c1c;
    transition: color var(--transition-fast);
  }

  .footer__links a:hover,
  .footer__contacts a:hover {
    color: var(--color-primary);
  }

  .footer__contacts {
    display: flex;
    flex-direction: column;
    gap: 1.125em; /* 18px */
  }

  .footer__contacts li {
    display: flex;
    align-items: center;
    gap: 0.85em; /* ~13.5px */
  }

  .footer__contacts img {
    flex-shrink: 0;
  }

  .footer__bar {
    width: 100%;
    background: var(--color-primary);
    color: var(--color-text-white);
  }

  .footer__bar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1em;
    min-height: 2.75em; /* 44px */
    padding-block: 0.5em;
  }

  .footer__legal {
    display: flex;
    align-items: center;
    gap: 1em; /* 16px */
    font-size: 0.875em; /* 14px */
    line-height: 1.3;
  }

  .footer__legal a {
    text-decoration: underline;
  }

  .footer__copy {
    font-size: 0.875em; /* 14px */
    line-height: 1.3;
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 991px) {
    .footer__main {
      flex-direction: column;
      gap: 2.5em;
    }

    .footer__nav {
      gap: 3em;
      flex-wrap: wrap;
    }
  }

  @media (max-width: 767px) {
    .footer__main {
      padding-top: 2.5em;
    }

    .footer__links {
      flex-direction: column;
      gap: 0.75em;
    }

    .footer__bar-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5em;
      padding-block: 0.85em;
    }

    .footer__legal {
      flex-wrap: wrap;
    }
  }
</style>
