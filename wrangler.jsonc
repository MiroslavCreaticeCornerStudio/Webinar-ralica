{
  // Static-assets-only Worker. This site is fully static (Astro `output: 'static'`),
  // so there is NO server code, NO SSR adapter, and NO bindings (KV/sessions/etc.).
  // `npm run build` outputs to ./dist, which is served directly from Cloudflare's edge.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "webinar-ralica",
  "compatibility_date": "2025-06-01",
  "assets": {
    "directory": "./dist"
  }
}
